AZURE_ORGANIZATION_NAME=your-organization-name
AZURE_API_VERSION=6.0
AZURE_PAT=your-personal-access-token

APP_DEFAULT_PROJECT=temp-workitems
APP_LOG_PATH=./logs

# SharePoint Configuration (Microsoft Graph API)
SHAREPOINT_CLIENT_ID=your-azure-ad-app-client-id
SHAREPOINT_CLIENT_SECRET=your-azure-ad-app-client-secret
SHAREPOINT_TENANT_ID=your-azure-ad-tenant-id
SHAREPOINT_SITE_ID=your-sharepoint-site-id

LOCAL_DOCKER_LAMP_PATH=path-demo
LOCAL_WWW_PATH=path-demo\apache\www
LOCAL_VHOSTS_FILE=path-demo\apache\vhosts\ci-apps.conf
LOCAL_HOSTS_FILE=\etc\hosts
LOCAL_BASE_ENV_FILE=path-demo\apache\www\app-plataformabase\html\.env

# Provision API
PROVISION_SALT=your-provision-salt
PROVISION_TIMEZONE=Europe/Berlin
PROVISION_DOMAIN_PRODUCTION=https://provision.example.com/
PROVISION_DOMAIN_DEVELOPMENT=https://provision-dev.example.com/
PROVISION_DOMAIN_LOCAL=http://host.docker.internal:3016/
PROVISION_ENVIRONMENT=development
