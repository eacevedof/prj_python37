# Azure DevOps
AZURE_API_VERSION=7.0
AZURE_ORGANIZATION_NAME=your-organization
AZURE_PAT=your-personal-access-token

# Application
APP_DEFAULT_PROJECT=your-default-project
APP_LOG_PATH=./logs

# SharePoint / Microsoft Graph
SHAREPOINT_CLIENT_ID=your-client-id
SHAREPOINT_CLIENT_SECRET=your-client-secret
SHAREPOINT_TENANT_ID=your-tenant-id
SHAREPOINT_SITE_ID=your-site-id

# Local Development (Docker LAMP)
LOCAL_DOCKER_LAMP_PATH=/path/to/docker-lamp
LOCAL_WWW_PATH=/path/to/www
LOCAL_VHOSTS_FILE=/path/to/vhosts.conf
LOCAL_HOSTS_FILE=/etc/hosts
LOCAL_BASE_ENV_FILE=/path/to/base.env

# EMT Madrid API (https://mobilitylabs.emtmadrid.es)
EMT_CLIENT_ID=your-emt-client-id
EMT_PASSKEY=your-emt-passkey
